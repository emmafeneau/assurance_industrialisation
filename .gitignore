# ── Python ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.so

# ── uv ──────────────────────────────────────────────
.venv/
.uv/

# ── Environnement ────────────────────────────────────
.env
.env.*
!.env.example

# ── Données ──────────────────────────────────────────
data/*.csv
data/*.parquet
data/*.xlsx
!data/.gitkeep

# ── Modèles ML (trop lourds pour git) ────────────────
# Décommentez si vous préférez ne pas versionner les .pkl
# frequence/models/*.pkl
# severite/models/*.pkl

# ── Outputs intermédiaires ───────────────────────────
frequence/outputs/*
severite/outputs/*
prime/outputs/*
!frequence/outputs/gitkeep
!severite/outputs/gitkeep
!prime/outputs/gitkeep

# ── CatBoost info ────────────────────────────────────
catboost_info/
frequence/src/catboost_info/
severite/src/catboost_info/

# ── IDE ──────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker ───────────────────────────────────────────
postgres_data/

# ── Tests ────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
